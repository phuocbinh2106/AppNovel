<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_main"
        app:navigationIcon="@drawable/ic_arrow_back">

        <TextView
            android:id="@+id/tvChapterHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÊM CHAPTER MỚI"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#60a5fa"
            android:layout_marginEnd="48dp"/>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên chương (Ví dụ: Chương 1: Sự khởi đầu)"
                app:hintTextColor="#60a5fa"
                app:boxStrokeColor="#60a5fa"
                android:textColorHint="#6b7280"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtChapterTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#ffffff"
                    android:inputType="textCapSentences"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Giá xu (0 nếu miễn phí)"
                app:hintTextColor="#60a5fa"
                app:boxStrokeColor="#60a5fa"
                android:textColorHint="#6b7280"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtChapterPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#ffffff"
                    android:inputType="number"
                    android:text="0"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadTxt"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="TẢI LÊN TỪ FILE .TXT"
                android:textColor="#60a5fa"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_upload"
                app:iconTint="#60a5fa"
                app:strokeColor="#60a5fa" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nội dung chương truyện"
                app:hintTextColor="#60a5fa"
                app:boxStrokeColor="#60a5fa"
                android:textColorHint="#6b7280"
                android:layout_marginBottom="32dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtChapterContent"
                    android:layout_width="match_parent"
                    android:layout_height="400dp"
                    android:textColor="#ffffff"
                    android:gravity="top"
                    android:inputType="textMultiLine"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddChapter"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="XUẤT BẢN CHAPTER"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#60a5fa"
                android:textColor="#ffffff"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>