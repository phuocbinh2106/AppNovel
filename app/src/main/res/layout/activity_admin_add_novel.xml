<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÊM TRUYỆN MỚI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:textColor="#fb923c"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin cơ bản"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtNovelTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Tên bộ truyện"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtNovelAuthor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Tên tác giả"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtNovelImageUrl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Link ảnh bìa"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtNovelDesc"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Mô tả nội dung..."
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:gravity="top"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phân quyền Uploader"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/spinnerUploader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnAddNovel"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="LƯU TRUYỆN MỚI"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#fb923c"
            android:textColor="#ffffff"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>
