<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOOLBAR ── -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1a1a1a"
            app:titleTextColor="#ffffff"
            app:navigationIcon="@drawable/ic_arrow_back">

            <!-- Nút settings bên phải -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="end|center_vertical"
                android:paddingEnd="8dp">

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Cài đặt"
                    app:tint="#ffffff"/>

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- ── NỘI DUNG CHÍNH ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ScrollView đọc truyện -->
            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:id="@+id/tvChapterTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"
                        android:gravity="center"
                        android:layout_gravity="center"/>

                    <TextView
                        android:id="@+id/tvContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#e5e7eb"
                        android:textSize="16sp"
                        android:lineSpacingExtra="8dp"/>

                </LinearLayout>
            </ScrollView>

            <!-- ── MÀN HÌNH KHÓA (ẩn mặc định) ── -->
            <LinearLayout
                android:id="@+id/layoutLocked"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/bg_main"
                android:paddingHorizontal="32dp"
                android:visibility="gone">

                <!-- Icon khóa -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="56sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Tiêu đề chapter -->
                <TextView
                    android:id="@+id/tvLockedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Mô tả -->
                <TextView
                    android:id="@+id/tvLockedDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#9ca3af"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp"/>

                <!-- Nút 1: Mua vé tháng -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuyMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:text="✨  Mua vé tháng"
                    android:textSize="15sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#7c3aed"
                    app:cornerRadius="26dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2d2d2d"
                    android:layout_marginBottom="12dp"/>

                <!-- Nút 2: Mở khóa bằng xu -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnlockCoin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:textSize="15sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#16a34a"
                    app:cornerRadius="26dp"/>

                <!-- Nút 3: Auto-unlock bằng xu (toggle) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="#1f1f1f"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1f1f1f">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔄  Mở chương tự động bằng xu"
                        android:textColor="#ffffff"
                        android:textSize="14sp"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchAutoUnlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <!-- Nút 4: Nạp xu -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTopUpCoin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="€  Nạp Xu"
                    android:textSize="15sp"
                    android:textColor="#60a5fa"
                    app:strokeColor="#60a5fa"
                    app:cornerRadius="26dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- ── BOTTOM NAV: chỉ Chương trước / Chương sau ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1a1a1a"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="← Chương trước"
                android:textSize="13sp"
                android:backgroundTint="#374151"
                android:textColor="#ffffff"/>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Chương sau →"
                android:textSize="13sp"
                android:backgroundTint="#4ade80"
                android:textColor="#000000"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── SETTINGS BOTTOM SHEET ── -->
    <LinearLayout
        android:id="@+id/layoutSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#1a1a1a"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="#4b5563"
            android:layout_marginBottom="16dp"/>

        <!-- Tab: Thông tin / Chỉnh sửa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tabInfo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Thông tin"
                android:gravity="center"
                android:textColor="#9ca3af"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/tabEdit"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Chỉnh sửa"
                android:gravity="center"
                android:textColor="#60a5fa"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackground"/>

        </LinearLayout>

        <!-- Divider tab -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2d2d2d"
            android:layout_marginBottom="16dp"/>

        <!-- ── PANEL CHỈNH SỬA ── -->
        <LinearLayout
            android:id="@+id/panelEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Font chữ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Font chữ"
                    android:textColor="#9ca3af"
                    android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontSerif"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:text="Serif"
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    app:strokeColor="#374151"
                    app:cornerRadius="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontSans"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:text="Sans"
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    app:strokeColor="#374151"
                    app:cornerRadius="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontMono"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:text="Mono"
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    app:strokeColor="#374151"
                    app:cornerRadius="6dp"/>

            </LinearLayout>

            <!-- Cỡ chữ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Cỡ chữ"
                    android:textColor="#9ca3af"
                    android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontDecrease"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:text="A-"
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1f2937"
                    app:cornerRadius="22dp"
                    android:padding="0dp"/>

                <TextView
                    android:id="@+id/tvFontSize"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="16"
                    android:gravity="center"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontIncrease"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="A+"
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1f2937"
                    app:cornerRadius="22dp"
                    android:padding="0dp"/>

            </LinearLayout>

            <!-- Chiều cao dòng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Giãn dòng"
                    android:textColor="#9ca3af"
                    android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLineDecrease"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:text="-"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1f2937"
                    app:cornerRadius="22dp"
                    android:padding="0dp"/>

                <TextView
                    android:id="@+id/tvLineHeight"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:gravity="center"
                    android:textColor="#ffffff"
                    android:textSize="14sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLineIncrease"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#1f2937"
                    app:cornerRadius="22dp"
                    android:padding="0dp"/>

            </LinearLayout>

            <!-- Màu nền -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Màu nền"
                android:textColor="#9ca3af"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Hàng màu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- Hồng -->
                <View
                    android:id="@+id/colorPink"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#fce7f3"/>

                <!-- Xanh nhạt -->
                <View
                    android:id="@+id/colorBlue"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#dbeafe"/>

                <!-- Xám -->
                <View
                    android:id="@+id/colorGray"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#374151"/>

                <!-- Đen -->
                <View
                    android:id="@+id/colorBlack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#111111"/>

                <!-- Vàng nhạt -->
                <View
                    android:id="@+id/colorYellow"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#fef9c3"/>

                <!-- Trắng -->
                <View
                    android:id="@+id/colorWhite"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_purple"
                    android:backgroundTint="#ffffff"/>

            </LinearLayout>

            <!-- Mặc định -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDefault"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:text="Mặc Định"
                android:textSize="13sp"
                android:textColor="#9ca3af"
                app:strokeColor="#374151"
                app:cornerRadius="18dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>