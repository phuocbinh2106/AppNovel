<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1a1a1a"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:background="#4b5563"/>

    <!-- Mật khẩu cũ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="***"
            android:textColor="#9ca3af"
            android:textSize="16sp"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtOldPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Nhập mật khẩu cũ..."
            android:inputType="textPassword"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Quên mật khẩu -->
    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Quên mật khẩu?"
        android:textColor="#a78bfa"
        android:textSize="13sp"/>

    <!-- Mật khẩu mới -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="***"
            android:textColor="#9ca3af"
            android:textSize="16sp"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Nhập mật khẩu mới..."
            android:inputType="textPassword"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Xác nhận mật khẩu mới -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_card_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_shield"
            app:tint="#9ca3af"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtConfirmNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Xác nhận lại mật khẩu mới..."
            android:inputType="textPassword"
            android:textColor="#ffffff"
            android:textColorHint="#6b7280"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Nút Thay đổi -->
    <Button
        android:id="@+id/btnThayDoi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:backgroundTint="#a78bfa"
        android:text="Thay đổi"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>