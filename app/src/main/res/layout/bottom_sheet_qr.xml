<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1e2a2a"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#4b5563" />

    <!-- QR Code -->
    <ImageView
        android:id="@+id/imgQr"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="#ffffff"
        android:padding="8dp"
        android:scaleType="fitCenter" />

    <!-- Nút lưu QR -->
    <TextView
        android:id="@+id/btnLuuQr"
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_btn_save_qr"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:text="Lưu ảnh QR Code"
        android:textColor="#1a1a1a"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Thông tin chuyển khoản -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <!-- Ngân hàng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngân hàng: "
                android:textColor="#d1d5db"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTenNganHang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Số tài khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tài khoản nhận: "
                android:textColor="#d1d5db"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSoTK"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCopySoTK"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="[ Copy ]"
                android:textColor="#60a5fa"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tên người nhận -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên người nhận: "
                android:textColor="#d1d5db"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTenNguoiNhan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCopyTen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="[ Copy ]"
                android:textColor="#60a5fa"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nội dung (mã nạp) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nội dung: "
                android:textColor="#d1d5db"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvNoiDung"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCopyNoiDung"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="[ Copy ]"
                android:textColor="#60a5fa"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Số tiền -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số tiền: "
                android:textColor="#d1d5db"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSoTien"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#f59e0b"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="16dp"
            android:background="#374151" />

        <!-- Chú ý -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Chú ý"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="1. Kiểm tra đúng số tài khoản và tên chủ tài khoản và tên ngân hàng trước khi chuyển khoản."
            android:textColor="#ef4444"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="2. Không điền thêm bất kỳ chữ cái hoặc ký tự nào ngoài nội dung mã nạp có sẵn. Chuyển chính xác số tiền."
            android:textColor="#9ca3af"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="3. Nếu có thắc mắc về vấn đề chuyển khoản, vui lòng liên hệ fanpage."
            android:textColor="#9ca3af"
            android:textSize="13sp" />

        <!-- 2 nút Hủy / Hoàn thành -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnHuy"
                android:layout_width="100dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_btn_amber"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:text="Hủy"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnHoanThanh"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_btn_green"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:text="Hoàn thành"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>