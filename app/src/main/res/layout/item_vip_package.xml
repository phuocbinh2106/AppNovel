<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVip"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="16dp"
    app:cardBackgroundColor="@color/vip_yellow_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:strokeColor="#FF6B6B"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        :paddingBottom="16dp">

        <ImageView
            android:id="@+id/imgBadge"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_star"
            app:tint="@color/vip_yellow_text"/>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="GÓI THÀNH VIÊN THANH ĐỒNG"
            android:textColor="@color/vip_yellow_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="100.000 xu"
            android:textColor="#78350f"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="( Hiệu lực 1 tháng )"
            android:textColor="#78350f"
            android:textSize="12sp"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>